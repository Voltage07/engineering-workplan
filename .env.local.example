# ==========================================================
# .env.local — Environment Variables
# ==========================================================
#
# IMPORTANT:
# This file is listed in .gitignore — it will NEVER be
# uploaded to GitHub. Your secrets stay on your machine.
#
# HOW TO FILL THIS IN:
# 1. Go to https://supabase.com → your project
# 2. Click Settings (gear icon) → API
# 3. Copy "Project URL" and paste below
# 4. Copy "anon / public" key and paste below
#
# ==========================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-key-here
