# ==========================================================
# .gitignore
# Files and folders that should NEVER go to GitHub
# ==========================================================

# Dependencies — installed locally, never committed
node_modules/

# Build output — generated by `npm run build`
.next/
out/

# Environment variables — contains your SECRET KEYS
# This is the most important one. Never remove this line.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
